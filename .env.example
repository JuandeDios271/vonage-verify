# Puerto en el que correrá el servidor Express dentro del contenedor
PORT=3000

# Claves de API de Vonage
# Úsalas para enviar y verificar códigos SMS
VONAGE_API_KEY=tu_api_key
VONAGE_API_SECRET=tu_api_secret

# URI de conexión a MongoDB (formato sin autenticación, usado por default)
# Si habilitas autenticación, remplaza por:
# mongodb://<usuario>:<contraseña>@mongo:27017/verifications?authSource=admin
MONGO_URI=mongodb://mongo:27017/verifications

# Orígenes permitidos para CORS (separados por coma)
# Agrega los dominios que usarán tu API (web, móvil, etc.)
CORS_ORIGINS=https://miapp.com,capacitor://localhost

# Credenciales para autenticación básica (ej. en endpoints protegidos)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=admin123

# Variables para inicializar MongoDB con usuario root (usadas por el contenedor)
# Estas se utilizan solo al crear el contenedor de Mongo por primera vez
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=tuPasswordSegura123
